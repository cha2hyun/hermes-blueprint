# === ops-orchestrator .env 템플릿 — install.sh가 .env로 복사, 값은 사람이 입력 (chmod 600) ===
# LLM API 키 (Anthropic Console 종량 키 — install.sh가 루트 .env에서 자동 주입)
ANTHROPIC_API_KEY=
# 이 도메인 전용 Discord 봇 토큰 (@BotFather/Developer Portal)
DISCORD_BOT_TOKEN=
# 본인 Discord 사용자 ID(쉼표 구분) — 명령 allowlist
DISCORD_ALLOWED_USERS=
# 비공개 서버 전원 허용 (allowlist 대신, 선택)
GATEWAY_ALLOW_ALL_USERS=true
# 이 봇 전용 채널 ID — config.yaml의 ${DISCORD_OPS_CHANNEL} 가 참조 (Discord 채널 생성 후 입력)
DISCORD_OPS_CHANNEL=
